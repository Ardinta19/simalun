# ════════════════════════════════════════════════════════════════════
# .env.production.example
#
# Template environment untuk deploy production. Copy jadi `.env`,
# isi placeholder bertanda __ISI__, lalu jalanin `php artisan key:generate`.
#
# JANGAN commit `.env` produksi yang sudah berisi kredensial nyata —
# file ini cuma TEMPLATE.
#
# Lihat docs/deployment.md untuk panduan deploy lengkap dan
# checklist pre/post-deploy.
# ════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────

APP_NAME="Azka Laundry SIMALUN"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://__DOMAIN_PRODUKSI__

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Production: pakai 12 (default Laravel) untuk balance security/perf.
# Naikkan ke 14 kalau hardware kuat dan butuh hardening ekstra.
BCRYPT_ROUNDS=12

# ─── Logging ─────────────────────────────────────────────────────────

# `daily` rotasi otomatis 14 hari — cocok untuk produksi tanpa harus
# setup logrotate eksternal. `stack` channel pisah error vs info.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null

# `error` di production supaya log gak banjir info/debug. Kalau lagi
# diagnosis incident, sementara naikkan ke `debug` lalu kembalikan.
LOG_LEVEL=error

# ─── Database ────────────────────────────────────────────────────────

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=__NAMA_DATABASE__
DB_USERNAME=__USER_DATABASE__
DB_PASSWORD=__PASSWORD_DATABASE__

# Catatan: jangan pakai user `root` di produksi. Bikin user khusus
# dengan grant minimal:
#   CREATE USER 'azka'@'localhost' IDENTIFIED BY '...';
#   GRANT SELECT, INSERT, UPDATE, DELETE, CREATE, ALTER, INDEX, DROP, REFERENCES
#         ON azka_laundry.* TO 'azka'@'localhost';

# ─── Session ─────────────────────────────────────────────────────────

# `database` driver supaya session sticky kalau scale ke multi-server.
# `cookie` driver bisa jadi alternatif kalau single-server (lebih cepat
# tapi cookie size limit ~4KB).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=null

# WAJIB di produksi:
# SESSION_ENCRYPT=true   — payload session di-encrypt simetris pakai APP_KEY
# SESSION_SECURE_COOKIE=true — cookie cuma kirim via HTTPS (mismatch HTTP = no cookie)
# SESSION_SAME_SITE=lax  — block CSRF cross-site, tetap allow nav ke link
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ─── Broadcasting ────────────────────────────────────────────────────

# `log` = nonaktif efektif. Kalau next iteration aktifkan broadcasting
# Reverb (lihat docs/realtime.md), ganti ke `reverb`.
BROADCAST_CONNECTION=log

# ─── Filesystem ──────────────────────────────────────────────────────

# `local` = storage/app, `public` = storage/app/public (perlu storage:link).
# Kalau migrasi ke S3 nanti, ganti FILESYSTEM_DISK=s3 dan isi AWS_*.
FILESYSTEM_DISK=public

# ─── Queue ───────────────────────────────────────────────────────────

# `database` cocok untuk single-server tanpa Redis.
# Worker WAJIB jalan via supervisor/systemd — lihat docs/deployment.md.
QUEUE_CONNECTION=database

# ─── Cache ───────────────────────────────────────────────────────────

# `database` driver — cache disimpan di tabel `cache`. Cocok kalau belum
# pakai Redis. Untuk traffic tinggi (>100 req/menit) pertimbangkan redis.
CACHE_STORE=database
# CACHE_PREFIX=azka_

# Dashboard admin punya 6 segment analitik di-cache 60 detik.
# Manual flush via: php artisan cache:clear

# ─── Redis (opsional) ────────────────────────────────────────────────

# Aktifkan kalau switch CACHE_STORE/SESSION_DRIVER ke redis.
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=__REDIS_PASSWORD_KALAU_ADA__
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1

# ─── Mail (untuk reset password & notifikasi customer) ───────────────

# Production WAJIB pakai SMTP beneran — `log` driver gak ngirim ke user.
# Provider yang umum: Mailtrap (testing), Resend, SendGrid, Brevo,
# atau SMTP Hostinger / Gmail SMTP.
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=__SMTP_HOST__
MAIL_PORT=587
MAIL_USERNAME=__SMTP_USERNAME__
MAIL_PASSWORD=__SMTP_PASSWORD__
MAIL_FROM_ADDRESS="no-reply@__DOMAIN_PRODUKSI__"
MAIL_FROM_NAME="${APP_NAME}"

# Catatan: deliverability email sangat tergantung domain authentication.
# Pastikan DNS punya:
#   - SPF record yang include provider mail
#   - DKIM key dari provider mail
#   - DMARC policy minimum p=none (better p=quarantine setelah stabil)
# Tanpa ini, email reset password kemungkinan masuk spam.

# ─── AWS S3 (kalau pakai disk s3) ────────────────────────────────────

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Vite ────────────────────────────────────────────────────────────

VITE_APP_NAME="${APP_NAME}"

# ─── Realtime mode (driver dashboard) ────────────────────────────────

# Default `polling` — JS poll setiap 30 detik. Bandwith hemat, jalan
# di shared hosting. Untuk realtime broadcasting via Reverb, set
# `broadcasting` (butuh setup Reverb + Nginx reverse proxy — lihat
# docs/realtime.md).
DRIVER_REALTIME_MODE=polling

# ─── Strategi Auto-assign Driver ─────────────────────────────────────

# round_robin (default) — pilih driver dengan last_assigned_at paling
# lama, distribusi merata.
# load_based — pilih driver dengan beban order aktif terkecil, adil
# saat ada order yang makan waktu lebih lama.
DRIVER_ASSIGNMENT_STRATEGY=round_robin

# ─── Identitas Bisnis Laundry ────────────────────────────────────────

# Dipakai di header nota, footer email, halaman bantuan, dll.
# Edit sesuai data Azka aktual.
LAUNDRY_NAME="Azka Laundry"
LAUNDRY_TAGLINE="Layanan Laundry Terpercaya"
LAUNDRY_ADDRESS="Mayang Mangurai, Kota Baru, Jambi City, Jambi"
LAUNDRY_GMAPS="https://maps.app.goo.gl/gArdhsRxYnPkRwDq8"
LAUNDRY_PHONE="082378886053"
LAUNDRY_PHONE_DISPLAY="0823-7888-6053"
LAUNDRY_WA="6282378886053"
